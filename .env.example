# Copie para .env e ajuste (o arquivo .env não deve ser versionado).
#
# Se a migração PRISMA5 não achar sps-prisma5/*.sql (cwd na pasta do .fdb, atalho, etc.):
# GO_PROJECT_DIR=C:/Projetos/primesoftware/prime-migration-v3

# Log em arquivo (append). Padrão: migration.log no diretório de trabalho.
# PRIME_LOG_FILE=D:/logs/prime-migration.log
# PRIME_DISABLE_FILE_LOG=1
#
# Senha na tela (Firebird origem): defina PRIME_FIREBIRD_PASSWORD — o campo "Senha"
# já abre preenchido e, se estiver definida, não é gravada no config.db ao salvar.

# --- SQLite local (configs salvas, logs) ---
# Caminho do arquivo ou DSN completo modernc (se já tiver '?', usado como está).
# PRIME_CONFIG_DB_PATH=./config.db

# --- Histórico central Firebird (obrigatório para migrar) ---
# Opção A: DSN completo (senha pode ficar aqui)
# PRIME_HISTORY_DSN=sysdba:senha@localhost:3050/C:/caminho/migration_history.fdb?charset=WIN1252

# Opção B: partes (útil para não colocar senha no central.json)
# PRIME_HISTORY_USER=SYSDBA
# PRIME_HISTORY_PASSWORD=
# PRIME_HISTORY_HOST=localhost
# PRIME_HISTORY_PORT=3050
# PRIME_HISTORY_PATH=C:/caminho/migration_history.fdb
# PRIME_HISTORY_CHARSET=WIN1252

# --- Formulário: Firebird origem (pré-preenche a UI) ---
# PRIME_FIREBIRD_HOST=localhost
# PRIME_FIREBIRD_PORT=3050
# PRIME_FIREBIRD_PATH=C:/dados/origem.fdb
# PRIME_FIREBIRD_USER=SYSDBA
# PRIME_FIREBIRD_PASSWORD=   ← coloque aqui a senha do banco de origem (pré-preenche a UI)
# Com PRIME_FIREBIRD_PASSWORD definida, ao salvar config no SQLite a senha não é persistida.
# PRIME_FIREBIRD_CONVERSAO=1

# --- Formulário: Pharmacie destino ---
# PRIME_PHARMACIE_ALIAS=C:/caminho/g5.fdb
# PRIME_PHARMACIE_IPSERVER=localhost
# PRIME_PHARMACIE_PORT=3050
